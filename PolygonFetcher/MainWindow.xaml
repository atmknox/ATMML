<Window x:Class="PolygonFetcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="S&amp;P 500 Polygon Data Fetcher" Height="700" Width="900"
        Background="#1E1E1E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="S&amp;P 500 Polygon.io Data Fetcher" 
                       FontSize="24" FontWeight="Bold" Foreground="#E0E0E0"/>
            <TextBlock Text="Fetches historical bar data for all S&amp;P 500 constituents (Jan 2022 - Present)" 
                       FontSize="12" Foreground="#808080" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Interval:" VerticalAlignment="Center" Foreground="#E0E0E0" Margin="0,0,5,0"/>
            <ComboBox x:Name="IntervalCombo" Grid.Column="1" Width="80" Margin="0,0,15,0"
                      SelectedIndex="0">
                <ComboBoxItem Content="D" Tag="D"/>
                <ComboBoxItem Content="W" Tag="W"/>
                <ComboBoxItem Content="60" Tag="60"/>
                <ComboBoxItem Content="30" Tag="30"/>
                <ComboBoxItem Content="15" Tag="15"/>
                <ComboBoxItem Content="5" Tag="5"/>
                <ComboBoxItem Content="1" Tag="1"/>
            </ComboBox>

            <TextBlock Text="Start:" VerticalAlignment="Center" Foreground="#E0E0E0" Grid.Column="2" Margin="0,0,5,0"/>
            <DatePicker x:Name="StartDatePicker" Grid.Column="3" Width="120" Margin="0,0,15,0"/>

            <TextBlock Text="End:" VerticalAlignment="Center" Foreground="#E0E0E0" Grid.Column="4" Margin="0,0,5,0"/>
            <DatePicker x:Name="EndDatePicker" Grid.Column="5" Width="120" Margin="0,0,15,0"/>

            <Button x:Name="FetchButton" Content="Start Fetching" Grid.Column="7" 
                    Width="120" Height="30" Click="FetchButton_Click"
                    Background="#0078D4" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold"/>
            <Button x:Name="CancelButton" Content="Cancel" Grid.Column="8" 
                    Width="80" Height="30" Margin="10,0,0,0" Click="CancelButton_Click"
                    Background="#D32F2F" Foreground="White" BorderThickness="0"
                    IsEnabled="False"/>
        </Grid>

        <!-- Log Display -->
        <Border Grid.Row="2" BorderBrush="#333333" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="LogListBox" Background="#252526" Foreground="#E0E0E0"
                     BorderThickness="0" FontFamily="Consolas" FontSize="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" Foreground="{Binding TextColor}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Status Bar -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"
                         Background="#333333" Foreground="#0078D4"/>
            <TextBlock x:Name="StatusText" Grid.Column="1" Margin="10,0,0,0" 
                       VerticalAlignment="Center" Foreground="#E0E0E0"
                       Text="Ready"/>
        </Grid>
    </Grid>
</Window>
