            <Border Grid.Row="0" Height="36" Background="#1F2937"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="DragBar_MouseDown">
                <DockPanel Margin="16,0,8,0">
                    <TextBlock Text="Capital Markets Research  —  ATMML"
                               Foreground="White" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right"
                            Content="✕"
                            Foreground="#ffffff" Background="Transparent"
                            BorderThickness="0" FontSize="13"
                            Width="28" Height="28"
                            Cursor="Hand" VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#374151"/>
                                                    <Setter Property="Foreground" Value="#F87171"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </DockPanel>
            </Border>

            <!-- ── Login form ──────────────────────────────────────── -->
            <StackPanel Grid.Row="1" Margin="36,24,36,28">

                <!-- Logo / title -->
                <TextBlock Text="Sign In"
                           Foreground="#F9FAFB" FontSize="22"
                           FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="ATMML Portfolio"
                           Foreground="White" FontSize="16"
                           Margin="0,0,0,20"/>

                <!-- Username -->
                <TextBlock Text="USERNAME" Foreground="White" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtUsername"
                         Style="{StaticResource InputBox}"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,20"
                         KeyDown="Input_KeyDown"/>

                <!-- Password -->
                <TextBlock Text="PASSWORD" Foreground="White"  Style="{StaticResource FieldLabel}"/>
                <!-- Password field with show/hide toggle -->
                <Grid Margin="0,0,0,20" Height="34">
                    <PasswordBox x:Name="TxtPassword"
                                 Style="{StaticResource InputBox}"
                                 VerticalContentAlignment="Center"
                                 KeyDown="Input_KeyDown"/>
                    <!-- Plain text overlay (shown when eye is toggled on) -->
                    <TextBox x:Name="TxtPasswordVisible"
                             Style="{StaticResource InputBox}"
                             VerticalContentAlignment="Center"
                             Visibility="Collapsed"
                             KeyDown="Input_KeyDown"
                             Padding="10,0,36,0"/>
                    <!-- Eye toggle button -->
                    <Button x:Name="BtnShowPassword"
                            Width="30" Height="30"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,2,0"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Show / Hide password"
                            Click="BtnShowPassword_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1.0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <!-- Eye icon -->
                        <Path x:Name="EyeIcon" Fill="White" Stretch="Uniform"
                              Width="16" Height="16"
                              Data="M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z"/>
                    </Button>
                </Grid>

                <!-- Error message -->
                <TextBlock x:Name="TxtError"
                           Foreground="#EF4444" FontSize="11"
                           Margin="0,0,0,14" Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- Login button -->
                <Button x:Name="BtnLogin"
                        Content="Sign In"
                        Style="{StaticResource PrimaryBtn}"
                        Click="BtnLogin_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

