<Window x:Class="ATMML.Auth.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Management"
        Width="860" Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputBox" TargetType="Control">
            <Setter Property="Background"   Value="#1F2937"/>
            <Setter Property="Foreground"   Value="#F9FAFB"/>
            <Setter Property="BorderBrush"  Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="Padding"      Value="8,0"/>
            <Setter Property="FontSize"     Value="12"/>
        </Style>

        <!-- Dark dropdown for ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background"   Value="#1F2937"/>
            <Setter Property="Foreground"   Value="#F9FAFB"/>
            <Setter Property="BorderBrush"  Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="Padding"      Value="8,0"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1F2937"/>
                        <Setter Property="Foreground" Value="#F9FAFB"/>
                        <Setter Property="Padding"    Value="8,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <DockPanel>
                                                <Path DockPanel.Dock="Right" Fill="#F9FAFB"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Width="8" Height="4" Margin="6,0"
                                                      VerticalAlignment="Center"/>
                                                <ContentPresenter/>
                                            </DockPanel>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#1F2937"
                                        BorderBrush="#374151" BorderThickness="1"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"   Value="#374151"/>
            <Setter Property="Foreground"   Value="#F9FAFB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"       Value="28"/>
            <Setter Property="Padding"      Value="10,0"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4B5563"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BlueBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#2563EB"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#7F1D1D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#991B1B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" Background="#000000"
            BorderBrush="#FF124B72" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                              Color="Black" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Drag bar -->
            <Border Grid.Row="0" Background="#111827" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="DragBar_MouseDown">
                <DockPanel Margin="16,0" >
                    <Viewbox
                           Grid.Row="0" Grid.RowSpan="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,1,0,2">
                        <Canvas
                               Name="aa2" Margin="0,0,1,250" HorizontalAlignment="Center" Visibility="Visible">

                            <Path
                                   Canvas.Left="1.672" Canvas.Top="23.995" Width="228.609" Height="181.997" Data="F1 M 141.729,37.408 L 127.825,37.408 L 127.911,37.574 C 123.026,46.390 118.896,52.471 115.504,55.799 C 112.105,59.131 108.382,60.794 104.315,60.794 C 99.631,60.794 95.866,58.535 93.022,53.995 C 90.354,49.750 88.934,44.216 88.769,37.408 L 73.708,37.408 C 73.707,37.606 73.699,37.799 73.699,37.998 C 73.699,47.627 76.313,55.342 81.548,61.127 C 86.782,66.919 93.753,69.813 102.455,69.813 C 109.192,69.813 114.820,68.140 119.337,64.781 C 123.858,61.434 128.313,55.612 132.715,47.321 L 140.783,63.844 L 149.384,51.854 C 149.384,51.854 144.149,41.977 141.729,37.408 L 141.729,37.408 M 142.750,2.100 C 141.027,9.372 138.496,16.899 135.153,24.655 C 130.516,15.184 126.232,8.805 122.315,5.517 C 118.393,2.229 113.133,0.576 106.541,0.576 C 96.643,0.576 88.690,4.002 82.697,10.848 C 76.743,17.645 73.749,26.605 73.703,37.741 L 88.780,37.741 C 88.764,37.185 88.753,36.622 88.753,36.047 C 88.753,28.368 90.274,22.052 93.308,17.101 C 96.346,12.137 100.227,9.660 104.961,9.660 C 108.312,9.660 111.309,11.092 113.961,13.957 C 116.613,16.821 120.091,22.443 124.393,30.806 L 127.911,37.574 C 127.880,37.631 127.850,37.686 127.817,37.741 L 141.905,37.741 C 141.077,36.178 140.525,35.137 140.526,35.137 C 148.269,22.373 153.409,11.369 155.942,2.100 L 142.750,2.100 L 142.750,2.100 Z"
                                   Fill="#FF2395CE" RenderTransformOrigin="0.503,0.455" Stretch="Fill">
                                <Path.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform />
                                        <SkewTransform AngleY="-0.057" />
                                        <RotateTransform />
                                        <TranslateTransform Y="-2.9" />
                                    </TransformGroup>
                                </Path.RenderTransform>
                            </Path>

                            <Path
                                   Canvas.Left="190" Canvas.Top="169" Width="50" Height="33" Data="F1 M 152.368,56.080 L 142.873,69.656 L 161.778,69.656 L 152.368,56.080 L 152.368,56.080 Z"
                                   Fill="#FFBC0031" RenderTransformOrigin="0.487,0.678" Stretch="Fill" />
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="CMR User Management" Foreground="White" Margin="35,0,0,0"
                               FontSize="11" VerticalAlignment="Center"/>
                    <Button x:Name="BtnClose" DockPanel.Dock="Right"
                            Content="✕" Foreground="#ffffff" FontWeight="ExtraBold"
                            Background="Transparent" BorderThickness="0"
                            FontSize="12" Cursor="Hand"
                            Click="BtnClose_Click"/>
                </DockPanel>
            </Border>

            <!-- Main content: left = grid, right = edit panel -->
            <Grid Grid.Row="1" Margin="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <!-- ── User list ─────────────────────────────────────── -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="USERS" Foreground="#ffffff"
                               FontSize="11"  FontWeight="Medium"
                               Margin="4,0,0,8"/>

                    <DataGrid x:Name="UserGrid"
                              Grid.Row="1"
                              Background="Black"
                              Foreground="#F9FAFB"
                              BorderBrush="#FF124B72"
                              BorderThickness="1"
                              RowBackground="#1F2937"
                              AlternatingRowBackground="#243040"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#FF124B72"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              FontSize="12"
                              SelectionChanged="UserGrid_SelectionChanged">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"   Value="#111827"/>
                                <Setter Property="Foreground"   Value="#ffffff"/>
                                <Setter Property="FontSize"     Value="10"/>
                                <Setter Property="Padding"      Value="3,6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="USERNAME"  Binding="{Binding Username}"    Width="130"/>
                            <DataGridTextColumn Header="ROLE"      Binding="{Binding Role}"         Width="120"/>
                            <DataGridCheckBoxColumn Header="ACTIVE" Binding="{Binding IsActive}"    Width="60"/>
                            <DataGridTextColumn Header="LAST LOGIN" Binding="{Binding LastLogin, StringFormat='yyyy-MM-dd HH:mm'}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Add user button -->
                    <Button Grid.Row="2"
                            Content="+ Add User"  FontSize="12"
                            Style="{StaticResource BlueBtn}"
                            Margin="0,10,0,0" HorizontalAlignment="Left"
                            Width="100"
                            Click="BtnAddUser_Click"/>
                </Grid>

                <!-- ── Edit / Add panel ──────────────────────────────── -->
                <Border Grid.Column="2"
                        Background="#000000" CornerRadius="6"
                        BorderBrush="#FF124B72" BorderThickness="1"
                        Padding="16">
                    <StackPanel>

                        <TextBlock x:Name="PanelTitle"
                                   Text="SELECT A USER"
                                   Foreground="#ffffff" FontSize="11"
                                   FontWeight="Medium" Margin="0,0,0,16"/>

                        <!-- Fields (hidden until user selected / add pressed) -->
                        <StackPanel x:Name="EditFields" Visibility="Collapsed">

                            <TextBlock Text="USERNAME" Foreground="White" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtEditUsername"
                                     Style="{StaticResource InputBox}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="ROLE" Foreground="White" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CbRole"
                                      Style="{StaticResource DarkComboBox}"
                                      Margin="0,0,0,12"/>

                            <!-- Active toggle (edit only) -->
                            <CheckBox x:Name="ChkActive"
                                      Content="Account Active"
                                      Foreground="#ffffff" FontSize="12"
                                      Margin="0,0,0,12"/>

                            <!-- New password (add only / reset) -->
                            <TextBlock x:Name="LblPassword"
                                       Text="TEMP PASSWORD" Foreground="White" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="TxtNewPassword"
                                         Style="{StaticResource InputBox}"
                                         Margin="0,0,0,4"/>
                            <TextBlock x:Name="LblPasswordHint"
                                       Text="Leave blank to keep existing password"
                                       Foreground="#ffffff" FontSize="10"
                                       Margin="0,0,0,12"/>

                            <!-- Status message -->
                            <TextBlock x:Name="TxtEditStatus"
                                       Foreground="#34D399" FontSize="11"
                                       Visibility="Collapsed"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <TextBlock x:Name="TxtEditError"
                                       Foreground="#EF4444" FontSize="11"
                                       Visibility="Collapsed"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>

                            <!-- Save -->
                            <Button x:Name="BtnSaveUser"  Foreground="White"  FontSize="12"
                                    Content="Save"
                                    Style="{StaticResource BlueBtn}"
                                    Click="BtnSaveUser_Click"
                                    Margin="0,0,0,8"/>

                            <!-- Deactivate / Reactivate -->
                            <Button x:Name="BtnToggleActive"  Foreground="White"  FontSize="12"
                                    Content="Deactivate"
                                    Style="{StaticResource RedBtn}"
                                    Click="BtnToggleActive_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
