<Window x:Class="ATMML.Auth.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password"
        Width="380" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputBox" TargetType="PasswordBox">
            <Setter Property="Background"   Value="#1F2937"/>
            <Setter Property="Foreground"   Value="#F9FAFB"/>
            <Setter Property="BorderBrush"  Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"       Value="34"/>
            <Setter Property="Padding"      Value="10,0"/>
            <Setter Property="FontSize"     Value="13"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="#2563EB"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"       Value="34"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#374151"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4B5563"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" Background="#000000"
            BorderBrush="#374151" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                              Color="Black" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Drag bar -->
            <Border Grid.Row="0" Background="#1F2937" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="DragBar_MouseDown">
                <TextBlock Text="Change Password"
                           Foreground="#FFFFFF" FontSize="13"
                           VerticalAlignment="Center" Margin="16,0"/>
            </Border>

            <!-- Form -->
            <StackPanel Grid.Row="1" Margin="32,20,32,24">

                <!-- Forced change banner -->
                <Border x:Name="ForcedBanner"
                        Background="#92400E" CornerRadius="4"
                        Padding="10,8" Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <TextBlock Text="You must set a new password before continuing."
                               Foreground="#FEF3C7" FontSize="11"
                               TextWrapping="Wrap"/>
                </Border>

                <TextBlock Text="CURRENT PASSWORD" Foreground="#FFFFFF" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="TxtCurrent" Style="{StaticResource InputBox}"
                             Margin="0,0,0,12"/>

                <TextBlock Text="NEW PASSWORD" Foreground="#FFFFFF" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="TxtNew" Style="{StaticResource InputBox}"
                             Margin="0,0,0,12"/>

                <TextBlock Text="CONFIRM NEW PASSWORD" Foreground="#FFFFFF" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="TxtConfirm" Style="{StaticResource InputBox}"
                             Margin="0,0,0,6"/>

                <TextBlock x:Name="TxtError"
                           Foreground="#EF4444" FontSize="11"
                           Visibility="Collapsed" TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnCancel" Grid.Column="0" FontSize="13"
                            Content="Cancel"
                            Style="{StaticResource SecondaryBtn}"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnSave" Grid.Column="2" FontSize="13"
                            Content="Change Password"
                            Style="{StaticResource PrimaryBtn}"
                            Click="BtnSave_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
