                                            </Style>
                                        </CheckBox.Resources>
                                    </CheckBox>
                                </StackPanel>
                            </BlockUIContainer>

                            <Paragraph Margin="40,15,0,0">
                                Choosing the 'Use ML Models' checkbox displays the features used to train | test your ML Model
                                and opens the
                                <Run FontWeight="Regular" Foreground="#FF8C00">ML MODEL INTERVAL</Run>
                                and
                                <Run FontWeight="Regular" Foreground="#FF8C00">YOUR ML MODELS</Run>
