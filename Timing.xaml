                                     Cursor="Hand" FontSize="10" Foreground="White" GroupName="Ago"
                                     MouseEnter="TradeIdeas_MouseEnter" MouseLeave="TradeIdeas_MouseLeave" ToolTip="Price Bar Two Periods Back" />
                    </StackPanel>
                </Grid>

                <RadioButton Name="ATMResults" Grid.Row="6" Margin="12,5,0,0" Padding="2,0,0,3"
