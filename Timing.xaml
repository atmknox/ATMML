                             Content="AGAINST POSITION" FontSize="11" Foreground="White" GroupName="PortDependent"
                             Visibility="Hidden" />

                <Label Name="Calculate" Grid.Row="3" Margin="5,2,0,0" HorizontalAlignment="Left" Grid.RowSpan="2"
