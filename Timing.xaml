                       MouseLeave="Country_MouseLeave" MouseLeftButtonDown="REFRESH_MouseLeftButtonDown" ToolTip="Click to Calculate Spreadsheet"  />

                <!--<Label Name="ProgressTitle" Grid.Row="4" Grid.Column="0" Margin="4,0,0,0"
                       HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Content="Calculating"
                       FontFamily="Helvetica Neue" FontSize="10" FontWeight="Normal" Foreground="#FFFF8C00" />-->
                <TextBlock Name="ProgressBarLabel" Grid.Row="4" Grid.Column="1" Margin="10,0,0,0"
                           HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="10" Foreground="#FF00ccff" />

                <Grid Name="CompareToGrid" Grid.Row="14" Grid.RowSpan="2" Width="130"
                      Margin="0,0,0,0" Visibility="Collapsed">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="112" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                    </Grid.RowDefinitions>

                    <Rectangle Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2" Width="130"
                               Margin="0,0,0,0" Fill="Transparent" Stroke="#FF124b72" StrokeThickness="1" />

                    <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="4,0,0,0"
                           VerticalAlignment="Top" Background="Transparent" Content="COMPARE TO" FontSize="11"
                           Foreground="White" MouseEnter="Country_MouseEnter" MouseLeave="Country_MouseLeave" MouseLeftButtonDown="CompareToPortfolio_MouseDown" />
                    <Label Grid.Row="0" Grid.ColumnSpan="11" Margin="0,0,0,0" HorizontalAlignment="Right"
                           HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="Transparent" Content="&#x1392;"
                           FontFamily="Helvetica Neue" FontSize="12" FontWeight="Normal" Foreground="White"
                           MouseDown="ViewHelp_MouseDown" MouseEnter="Help_MouseEnter" MouseLeave="Help_MouseLeave" />

                    <Label Name="ComparePortfolio" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Margin="4,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent"
                           Content="" FontFamily="Helvetica Neue" FontSize="11" Foreground="#FF00CCFF" />

                </Grid>

                <!--<Rectangle Grid.Row="5" Grid.RowSpan="2" Grid.ColumnSpan="1" Width="130" Height="33"
           Margin="0,10,0,0" Fill="Transparent" Stroke="#FF124b72" StrokeThickness="1" />-->

                <Grid Grid.Row="5" Grid.Column="0" Background="Black" Width="130" Grid.ColumnSpan="1" Grid.RowSpan="17"
                     HorizontalAlignment="Left" Margin="0,12,0,0" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="1" Background="Black"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <Expander IsExpanded="True">
                                <Expander.Style>
                                    <Style TargetType="Expander">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Expander">
                                                    <StackPanel>
                                                        <ToggleButton IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                                      Background="Transparent" BorderThickness="0"
                                                                      HorizontalContentAlignment="Stretch" Padding="0" Cursor="Hand">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="{TemplateBinding Background}">
                                                                        <ContentPresenter HorizontalAlignment="Stretch"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                            <ContentPresenter ContentSource="Header"/>
                                                        </ToggleButton>
                                                        <ContentPresenter x:Name="ExpanderContent" Visibility="Collapsed" Content="{TemplateBinding Content}"/>
                                                    </StackPanel>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsExpanded" Value="True">
                                                            <Setter TargetName="ExpanderContent" Property="Visibility" Value="Visible"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Expander.Style>
                                <Expander.Header>
                                    <Border Height="22" Background="#1A2A3A" BorderBrush="#FF1E6FA0" BorderThickness="0,0,0,1" Margin="0,2,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="▾" FontSize="12" Foreground="#FFFFFF"
                                                       VerticalAlignment="Center" Margin="3,0,0,0"/>
                                            <TextBlock Grid.Column="1" Text="CONNECTIVITY" FontFamily="Helvetica Neue"
                                               FontSize="10" Foreground="White" VerticalAlignment="Center" Margin="2,2,0,0"/>
                                            <Button x:Name="BtnCatConnectivity" Grid.Column="2"
                                                       Content="●" FontSize="12" Foreground="Lime"
                                                       Background="Transparent" BorderThickness="0"
