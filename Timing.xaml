                <Grid Name="AgoGrid" Grid.Row="3" Grid.RowSpan="4" Margin="0,0,0,0"
                      Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                    </Grid.RowDefinitions>

                    <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="2" Width="130"
                               Margin="0,0,0,0" Fill="Transparent" Stroke="#FF124b72" StrokeThickness="1" />

                    <!--<Label Name="JustOneTitle" Grid.Row="0" Grid.ColumnSpan="2" Margin="4,0,0,0"
                           HorizontalAlignment="Left" VerticalAlignment="Center" Background="Transparent" Content="Time"
                           FontFamily="Helvetica Neue" FontSize="10" FontWeight="Normal" Foreground="PaleGreen" />-->

                    <Label Name="PlusTime" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,4,0"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Content="Next"
                           FontFamily="Helvetica Neue" FontSize="10" FontWeight="Normal" Foreground="#ff00ccff"
                           Visibility="Collapsed" />
                    <!--<Label Name="CurrentTime" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,4,0"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Content="Current"
                           FontFamily="Helvetica Neue" FontSize="10" FontWeight="Normal" Foreground="#ff00ccff"
                           Visibility="Visible" />-->
                    <Label Name="Ago1Time" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,0"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Content="1 Ago"
                           FontFamily="Helvetica Neue" FontSize="10" FontWeight="Normal" Foreground="#ff00ccff"
                           Visibility="Collapsed" />
                    <Label Name="Ago2Time" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,0"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Content="2 Ago"
                           FontFamily="Helvetica Neue" FontSize="11" FontWeight="Normal" Foreground="#ff00ccff"
                           Visibility="Collapsed" />


                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,8,0" HorizontalAlignment="Right"
                                VerticalAlignment="Top" Orientation="Horizontal" Visibility="Collapsed">
                        <RadioButton Name="CurrentBar" Margin="4,0,0,0" Padding="2,0,0,0" HorizontalAlignment="Left"
                                Background="White" BorderBrush="Black" Click="CurrentBar_Click" Content="0"
                                Cursor="Hand" FontSize="10" Foreground="White" GroupName="Ago"
                                IsChecked="True" MouseEnter="TradeIdeas_MouseEnter" MouseLeave="TradeIdeas_MouseLeave" ToolTip="Current Price Bar" />
                        <RadioButton Name="PlusML" Margin="4,0,0,0" Padding="2,0,0,0" HorizontalAlignment="Left"
                                     Background="White" BorderBrush="Black" Click="PlusBar_Click" Content="+1"
                                     Cursor="Hand" FontSize="10" Foreground="White" GroupName="Ago"
                                     MouseEnter="TradeIdeas_MouseEnter" MouseLeave="TradeIdeas_MouseLeave" ToolTip="Next Price Bar"  />
                        <RadioButton Name="PreviousBar" Margin="5,0,0,0" Padding="2,0,0,0" HorizontalAlignment="Left" Visibility="Collapsed"
                                     Background="White" BorderBrush="Black" Click="PreviousBar_Click" Content="-1"
