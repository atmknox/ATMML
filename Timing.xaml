                                     MouseEnter="TradeIdeas_MouseEnter" MouseLeave="TradeIdeas_MouseLeave" ToolTip="Price Bar One Period Back" />
                        <RadioButton Name="BarTwoAgo" Margin="5,0,0,0" Padding="2,0,0,0" HorizontalAlignment="Left"  Visibility="Collapsed"
