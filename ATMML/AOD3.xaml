<UserControl x:Class="ATMML.AOD3" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ATMML" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" Visibility="Visible" mc:Ignorable="d">

    <Grid Name="AODPanel" Grid.Row="0" Grid.Column="0" Margin="8,0,0,8"
          Background="Black" Visibility="Visible">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="23" />
            <RowDefinition Height="23" />
            <RowDefinition Height="23" />
            <RowDefinition Height="23" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Rectangle x:Name="BlueRec" Grid.Row="0" Grid.RowSpan="12" Grid.Column="0"
                   Grid.ColumnSpan="6" Margin="0,0,0,0" Fill="Black" Stroke="#FF124b72"
                   StrokeThickness="1" Visibility="Visible" />
        <Rectangle x:Name="WhiteRec" Grid.Row="0" Grid.RowSpan="12" Grid.Column="0"
                   Grid.ColumnSpan="6" Margin="0,0,0,0" Fill="Black" Stroke="WhiteSmoke"
                   StrokeThickness="1" Visibility="Collapsed" />
        <Rectangle Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="6" Height="1"
                   Margin="8,20,8,0" Fill="#FF124b72" />

        <Label Name="AddNewAOD" Grid.Row="0" Grid.Column="0" Margin="2,0,10,0"
               HorizontalAlignment="Left" VerticalAlignment="Center" Content="&#128930;" FontFamily="Helvetica Neue"
               FontSize="11" Foreground="White" MouseDown="AddNewAOD_MouseDown" MouseEnter="OurView_MouseEnter"
               MouseLeave="OurView_MouseLeave" />

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="7" HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <TextBox Name="TickerSymbol" Margin="0,0,5,0" HorizontalAlignment="right" VerticalAlignment="Center"
                     FontFamily="Helvetica Neue" FontSize="10" Foreground="White" Text="" />
            <!--<Label Name="Desc" Margin="5,2,0,0" Content="" FontFamily="Helvetica Neue"
                   FontSize="10" Foreground="#00ccff" />-->
        </StackPanel>

        <Label Name="CloseAOD" Grid.Row="0" Grid.Column="6" Margin="0,0,4,0"
               HorizontalAlignment="right" VerticalAlignment="Center" Content="&#88;" FontFamily="Helvetica Neue"
               FontSize="11" Foreground="white" MouseDown="CloseAOD_MouseDown" MouseEnter="OurView_MouseEnter"
               MouseLeave="OurView_MouseLeave" />

        <Label Name="SourceButton" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6"
               Margin="0,0,4,0" HorizontalAlignment="Right" VerticalAlignment="Center" Content="PX SOURCE"
               FontFamily="Helvetica Neue" FontSize="10" Foreground="white" MouseDown="SourceButton_MouseDown"
               MouseEnter="OurView_MouseEnter" MouseLeave="OurView_MouseLeave" ToolTip="Click to Select your Pricing Source" 
                  />

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6" HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <Label HorizontalAlignment="left" Content="Interval" FontFamily="Helvetica Neue" FontSize="10"
                   Foreground="#BDBDBD" />
            <TextBlock Name="IntervalText" Margin="0,5,0,0" Background="Black" FontFamily="Helvetica Neue"
                       FontSize="10" Foreground="#00CCFF" />
            <ComboBox Name="IntervalSelector" Width="20" Height="20" />
        </StackPanel>

        <Label Name="MLModel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6"
               Margin="4,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Content="ML MODEL"
               FontFamily="Helvetica Neue" FontSize="10" Foreground="White" MouseDown="SelectModel_MouseDown"
               MouseEnter="OurView_MouseEnter" MouseLeave="OurView_MouseLeave" ToolTip="Click to Select your ML Model" 
                  />

        <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="6" Margin="0,0,7,0"
               Padding="2" HorizontalAlignment="Right" VerticalAlignment="Top" Content="SAVE"
               FontFamily="Helvetica Neue" FontSize="10" Foreground="White" MouseEnter="OurView_MouseEnter"
               MouseLeave="OurView_MouseLeave" MouseLeftButtonDown="SaveMonitorSettings_MouseLeftButtonDown" ToolTip="Click to Save Monitor Settings" 
                  />


        <!--  Prediction Left Align  -->
        <StackPanel Grid.Row="2" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="7"
                    Margin="0,0,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
            <Label Name="Current" Margin="6,0,0,0" Padding="3" HorizontalAlignment="Left"
                   Content="CURRENT" FontFamily="Helvetica Neue" FontSize="10" Foreground="White"
                   MouseDown="SelectCurrent_MouseDown" MouseEnter="OurView_MouseEnter" MouseLeave="OurView_MouseLeave" ToolTip="Click for Current Bar Prediction"
                       />
            <Label Name="Next" Margin="0,0,0,0" Padding="3" HorizontalAlignment="Left"
                   Content="NEXT" FontFamily="Helvetica Neue" FontSize="10" Foreground="White"
                   MouseDown="SelectNext_MouseDown" MouseEnter="OurView_MouseEnter" MouseLeave="OurView_MouseLeave" ToolTip="Click for Next Bar Prediction"
                       />
        </StackPanel>

        <!--  Results  -->
        <StackPanel Grid.Row="2" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="7"
                    Margin="6,15,0,0" HorizontalAlignment="left" VerticalAlignment="Center" Orientation="Horizontal">
            <Label Padding="3" HorizontalAlignment="Left" VerticalAlignment="Center" Content="ML Model"
                   FontFamily="Helvetica Neue" FontSize="8" Foreground="#BDBDBD" />
            <Label Name="Model" Margin="2,0,0,0" Padding="3" Content="Name"
                   FontFamily="Helvetica Neue" FontSize="9" Foreground="#00ccff" />
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="6"
                    Margin="0,15,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
            <Label Margin="0,0,2,0" Padding="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                   Content="Scenario" FontFamily="Helvetica Neue" FontSize="8" Foreground="#BDBDBD" />
            <Label Name="Scenario" Margin="5,3,10,0" Padding="0" Content=""
                   FontFamily="Helvetica Neue" FontSize="9" Foreground="#00ccff" />
        </StackPanel>


        <!--  Prediction  -->
        <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="6" Margin="6,0,6,20"
               Padding="3" HorizontalAlignment="Left" VerticalAlignment="Top" Content="ML Model Prediction"
               FontFamily="Helvetica Neue" FontSize="8" Foreground="#BDBDBD" />

        <StackPanel Grid.Row="4" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="7"
                    Margin="4,10,0,0" HorizontalAlignment="left" VerticalAlignment="Center" Orientation="Horizontal">
            <Label Name="ForecastPrice" Margin="1,0,0,0" Padding="4" Content="CL"
                   FontFamily="Helvetica Neue" FontSize="9" Foreground="#BDBDBD" />
            <TextBlock Name="STPredict" Margin="0,0,0,0" Padding="4" FontFamily="Helvetica Neue"
                       FontSize="9" Foreground="lime" Text="" />
            <Label Name="AdjustedPrice" Margin="0,0,0,0" Padding="4" Content="Adj Px"
                   FontFamily="Helvetica Neue" FontSize="9" Foreground="#BDBDBD" />
            <!--<Label   Margin="0,0,0,0"  Content="| Acc =" FontFamily="Helvetica Neue" FontSize="11" Foreground="#BDBDBD" Padding="4" />-->
            <Label Name="Accuracy" Margin="0,0,0,0" Padding="4" Content=""
                   FontFamily="Helvetica Neue" FontSize="9" Foreground="#BDBDBD" />
        </StackPanel>

        <!--  Current PX Middle Align  -->
        <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="6" Margin="0,0,6,20"
               Padding="3" HorizontalAlignment="Right" VerticalAlignment="Center" Content="Current PX"
               FontFamily="Helvetica Neue" FontSize="8" Foreground="#BDBDBD" />
        <Label x:Name="Cl" Grid.Row="4" Grid.RowSpan="2" Grid.Column="0"
               Grid.ColumnSpan="6" Margin="0,17,8,0" Padding="0" HorizontalAlignment="Right"
               VerticalAlignment="top" Content="" FontFamily="Helvetica Neue" FontSize="9"
               Foreground="Transparent" />


        <!--  Score Right Align  -->
        <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="6" Margin="0,0,50,20"
               Padding="3" HorizontalAlignment="Right" VerticalAlignment="Center" Content="Score"
               FontFamily="Helvetica Neue" FontSize="8" Foreground="#BDBDBD" />
        <Label x:Name="STScore" Grid.Row="4" Grid.RowSpan="2" Grid.Column="0"
               Grid.ColumnSpan="6" Margin="0,17,52,0" Padding="0" HorizontalAlignment="Right"
               VerticalAlignment="top" Content="" FontFamily="Helvetica Neue" FontSize="9"
               Foreground="Transparent" />

        <!--  Current Trend  -->
        <Label x:Name="CurrentPosition" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="6"
               Margin="4,0,0,0" HorizontalAlignment="left" VerticalAlignment="Center" Content=""
               FontFamily="Helvetica Neue" FontSize="8" Foreground="#BDBDBD" />
        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="7" Margin="8,0,0,13"
                    Orientation="Horizontal">
            <Label x:Name="StrategyPosition" Padding="0" HorizontalAlignment="left" VerticalAlignment="Top"
                   Content="" FontFamily="Helvetica Neue" FontSize="9" Foreground="Transparent" />
            <Label x:Name="PressureMessage" Margin="8,0,0,0" Padding="0" HorizontalAlignment="left"
                   VerticalAlignment="Top" Content="" FontFamily="Helvetica Neue" FontSize="9"
                   Foreground="Transparent" />
        </StackPanel>

        <!--  Current Rec  -->
        <Label x:Name="CurrentRec" Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="6"
               Margin="4,0,0,0" HorizontalAlignment="left" VerticalAlignment="Center" Content=""
               FontFamily="Helvetica Neue" FontSize="8" Foreground="#BDBDBD" />
        <Label x:Name="ModelPosition" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="7"
               Margin="9,0,0,13" Padding="0" HorizontalAlignment="left" VerticalAlignment="Bottom"
               Content="" FontFamily="Helvetica Neue" FontSize="9" Foreground="Transparent" />

        <!--  Next Rec  -->
        <Label x:Name="NewRec" Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="6"
               Margin="4,0,0,0" HorizontalAlignment="left" VerticalAlignment="Center" Content=""
               FontFamily="Helvetica Neue" FontSize="8" Foreground="#BDBDBD" />
        <Label x:Name="ForecastPosition" Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="6"
               Margin="8,0,0,4" Padding="0" HorizontalAlignment="left" VerticalAlignment="Top"
               Content="" FontFamily="Helvetica Neue" FontSize="9" Foreground="Transparent" />

        <Rectangle x:Name="MouseRec" Grid.Row="3" Grid.RowSpan="10" Grid.Column="0"
                   Grid.ColumnSpan="6" Margin="1,1,1,1" Fill="#01000000" MouseDown="MouseRec_MouseDown"
                   Stroke="#01000000" StrokeThickness="1" Visibility="Visible" />

    </Grid>

</UserControl>

