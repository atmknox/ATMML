<UserControl x:Class="ATMML.PortfolioDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="348" d:DesignWidth="260">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="24" />
            <RowDefinition Height= "300"/>
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>
        <TreeView Grid.Row="1" Name="PortfolioTree" FontWeight="Normal" Background="White" Foreground="Black"></TreeView>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Label Content="ADD or REMOVE PORTFOLIOS"  Padding="10,0" Background="Transparent" Foreground="Black" HorizontalAlignment="Left" FontFamily="Helvetica Neue"  FontSize="12" VerticalAlignment="Center" FontWeight="Bold" Width="257" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button Content="Save" Width="100" Padding="0" Margin="2" IsDefault="True" Click="Save_Click" Cursor="Hand" FontSize="11"></Button>
            <Button Content="Cancel" Width="100" Padding="0" Margin="2" IsCancel="True" Click="Cancel_Click" IsDefault="False" Cursor="Hand" FontSize="11"></Button>
        </StackPanel>

    </Grid>
</UserControl>
