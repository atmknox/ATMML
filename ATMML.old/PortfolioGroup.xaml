            <Path Data="F1 M 68.174,26.412 L 73.499,18.312 L 62.901,18.312 L 68.174,26.412 L 68.174,26.412 Z" Fill="#ff000000" />
        </Canvas>

        <Style x:Key="{x:Type ToolTip}" TargetType="{x:Type ToolTip}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Background" Value="Black" />
            <Setter Property="Foreground" Value="WhiteSmoke" />
        </Style>
    </ContentControl.Resources>

    <Viewbox Stretch="Fill">

        <Grid Background="Black">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="35" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />

            </Grid.ColumnDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6" Margin="0,0,0,0"
                HorizontalAlignment="Left" VerticalAlignment="Center" Background="Transparent" Content="Entry | Exit Signals"
                FontFamily="Helvetica Neue" FontSize="12" FontWeight="Normal" Foreground="#FFFF8C00"
                Visibility="Visible" />
            <RadioButton x:Name="LongOnly" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6"
                Margin="5,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Background="White"
                Content="LONG ONLY" Cursor="Hand" FlowDirection="RightToLeft" FontFamily="Helvetica Neue"
                FontSize="12" FontWeight="Normal" Foreground="White" GroupName="PositionDirection"
                IsChecked="False" Visibility="Visible" />

             <RadioButton x:Name="ShortOnly" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6"
                Margin="0,10,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Background="White"
                Content="SHORT ONLY" Cursor="Hand" FlowDirection="RightToLeft" FontFamily="Helvetica Neue"
                FontSize="12" FontWeight="Normal" Foreground="White" GroupName="PositionDirection"
                IsChecked="False" Visibility="Visible" />

            <RadioButton x:Name="LongShort" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6"
                Margin="0,10,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" Background="White"
                Content="LONG | SHORT" Cursor="Hand" FlowDirection="RightToLeft" FontFamily="Helvetica Neue"
                FontSize="12" FontWeight="Normal" Foreground="White" GroupName="PositionDirection"
                IsChecked="True" Visibility="Visible" />
            
            <RadioButton Name="UseMTNToff" Grid.Row="2" Grid.Column="0" Margin="2,5,0,0"   Padding="5,0,0,0"  Grid.ColumnSpan="2" Content="OFF" 
                         HorizontalAlignment="Left" VerticalAlignment="Center" Background="White" BorderBrush="Transparent"
                         Cursor="Hand" FlowDirection="LeftToRight" FontSize="12"
                         Foreground="White" IsChecked="False" GroupName="mtnt" Unchecked="UseATM_Unchecked">
                <RadioButton.Resources>
                    <Style TargetType="{x:Type Path}">
                        <Setter Property="FlowDirection" Value="LeftToRight" />
                    </Style>
                </RadioButton.Resources>
            </RadioButton>

            <RadioButton Name="UseMTNT" Grid.Row="2" Grid.Column="1" Margin="0,5,0,0"  Padding="5,0,0,0"  Grid.ColumnSpan="2" Content="MT NT" 
                          HorizontalAlignment="Left" VerticalAlignment="Center" Background="White" BorderBrush="Transparent"
                          Cursor="Hand" FlowDirection="LeftToRight" FontSize="12"
                          Foreground="White" IsChecked="False" GroupName="mtnt" Unchecked="UseATM_Unchecked">
                <RadioButton.Resources>
                    <Style TargetType="{x:Type Path}">
                        <Setter Property="FlowDirection" Value="LeftToRight" />
                    </Style>
                </RadioButton.Resources>
            </RadioButton>

            <RadioButton Name="UseNTPlus1" Grid.Row="2" Grid.Column="2" Margin="10,5,0,0"  Padding="5,0,0,0"  Grid.ColumnSpan="12" Content="MT NT 1" 
                          HorizontalAlignment="Left" VerticalAlignment="Center" Background="White" BorderBrush="Transparent"
                          Checked="UseATM_Checked" Cursor="Hand" FlowDirection="LeftToRight" FontSize="11" GroupName="mtnt"
                          Foreground="White" IsChecked="True" MouseEnter="Portfolio_MouseEnter" MouseLeave="Portfolio_MouseLeave2"  Unchecked="UseATM_Unchecked">
                <RadioButton.Resources>
                    <Style TargetType="{x:Type Path}">
                        <Setter Property="FlowDirection" Value="LeftToRight" />
                    </Style>
                </RadioButton.Resources>
            </RadioButton>

            <RadioButton Name="UseMTSecNT" Grid.Row="2" Grid.Column="3" Margin="55,5,0,5"  Padding="5,0,0,0"  Grid.ColumnSpan="3" Content="S MT NT1" 
                          HorizontalAlignment="Left" VerticalAlignment="Center" Background="White" BorderBrush="Transparent"
                          Cursor="Hand" FlowDirection="LeftToRight" FontSize="11"
                          Foreground="White" IsChecked="False" GroupName="mtnt"  Unchecked="UseATM_Unchecked">
                <RadioButton.Resources>
                    <Style TargetType="{x:Type Path}">
                        <Setter Property="FlowDirection" Value="LeftToRight" />
                    </Style>
                </RadioButton.Resources>
            </RadioButton>

        </Grid>
    </Viewbox>
    </UserControl>
