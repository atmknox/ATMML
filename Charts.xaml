                    <RowDefinition Height="25" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="25" />

                </Grid.RowDefinitions>
                <Rectangle Grid.Row="0" Grid.RowSpan="24" Margin="2,0,0,2" Fill="Transparent"
                           Stroke="#FF124b72" StrokeThickness="1" />
                <!--<Rectangle Grid.Row="12" Grid.RowSpan="12" Margin="2,2,0,0" Fill="Transparent"
                           Stroke="#FF124b72" StrokeThickness="1" />-->

                <Rectangle Grid.Row="1" Height="1" Margin="7,0,5,1" VerticalAlignment="Bottom"
                           Fill="Transparent" Stroke="#FF124B72" StrokeThickness="1" />
                <Rectangle Grid.Row="0" Height="1" Margin="7,0,5,0" VerticalAlignment="Bottom"
                           Fill="Transparent" Stroke="#FF124B72" StrokeThickness="1" />

                <Label Name="Portfolios" Grid.Row="0" Margin="4,0,0,0" HorizontalAlignment="Left"
                       VerticalAlignment="Center" Background="Transparent" Content="SECURITY LIST" Cursor="Hand"
                       FontFamily="Helvetica Neue" FontSize="11" Foreground="White" MouseEnter="Country_MouseEnter"
                       MouseLeave="Country_MouseLeave" MouseLeftButtonDown="Portfolio_MouseDown"  />

                <Label Grid.Row="2" Margin="4,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                       Background="Transparent" Content="Scenario" FontFamily="Helvetica Neue" FontSize="10"
                       Foreground="#00ccff" Visibility="Collapsed" />

                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,0" HorizontalAlignment="Left"
                            VerticalAlignment="Top" Orientation="Horizontal"  Visibility="Collapsed">
                    <Label Margin="4,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent"
                           Content="PREDICTION" FontFamily="Helvetica Neue" FontSize="11" Foreground="White" />
                    <RadioButton Name="Current" Margin="7,5,0,0" Padding="5,0,0,0" HorizontalAlignment="Left"
                                 Background="White" BorderBrush="Black" Checked="Current_Checked" Content="0" 
                                 Cursor="Hand" FontSize="10" Foreground="White" GroupName="Ago"
                                 IsChecked="True" ToolTip="Current Bar Prediction"  
                                   />
                    <RadioButton Name="Plus1" Margin="4,5,0,0" Padding="2,0,0,0" HorizontalAlignment="Right"
                                 Background="White" BorderBrush="Black" Checked="Plus1_Checked" Content="+1"
                                 Cursor="Hand" FontSize="10" Foreground="White" GroupName="Ago"
                                 ToolTip="Prediction One Price Bar Forward"   
                                  />
                </StackPanel>

                <Label Name="Country" Grid.Row="1" Margin="4,0,0,0" HorizontalAlignment="Left"
                       VerticalAlignment="Top" Background="Transparent" Content="" FontFamily="Helvetica Neue"
                       FontSize="10" Foreground="#FF00CCFF" />
                <Label Name="Portfolios2" Grid.Row="2" Margin="4,0,0,0" HorizontalAlignment="Left"
                       VerticalAlignment="Top" Background="Transparent" Content="POSITION OVERLAY" Cursor="Hand"
                       FontFamily="Helvetica Neue" FontSize="10" Foreground="White" MouseEnter="Country_MouseEnter"
                       MouseLeave="Country_MouseLeave" MouseLeftButtonDown="Portfolio2_MouseDown" ToolTip="Overlay other Portfolio Positions to chosen Portfolio" Visibility="Collapsed" />
                <Label Name="Country2" Grid.Row="3" Margin="4,0,0,5" HorizontalAlignment="Left"
                       VerticalAlignment="Top" Background="Transparent" Content="" FontFamily="Helvetica Neue"
                       FontSize="10" Foreground="#FF00CCFF" Visibility="Collapsed" />
                <Label Grid.Row="4" Height="25" HorizontalAlignment="Left" Background="Transparent"
                       Content="" />

                <Grid Name="MLScenario" Grid.Row="12" Grid.RowSpan="12" Width="130"
                      Margin="0,2,0,0" Visibility="Collapsed">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="126" />
                        <ColumnDefinition Width="4" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                    </Grid.RowDefinitions>

                    <Rectangle Grid.Row="0" Height="1" Margin="7,0,1,0" VerticalAlignment="Bottom"
                               Fill="Transparent" Stroke="#FF124B72" StrokeThickness="1" />

                    <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="4,0,0,0"
                           VerticalAlignment="Top" Background="Transparent" Content="ML Prediction Models" FontSize="11"
                           Foreground="#FFFF8C00" />

                    <ScrollViewer Grid.Row="1" Grid.RowSpan="11" Grid.ColumnSpan="2" Margin="2,0,2,5">
                        <Grid Name="ScenarioModels">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ScrollViewer>

                </Grid>

                <Label Name="ScenarioLabel" Grid.Row="2" Grid.Column="0" Margin="0,0,4,0"
                       HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" Content=""
                       FontFamily="Helvetica Neue" FontSize="10" Foreground="#FF00CCFF" Visibility="Collapsed"/>

                <Grid Name="Progress" Grid.Row="3" Margin="2,0,2,3" VerticalAlignment="Bottom"
                      Visibility="Visible">

                    <ProgressBar Name="ProgressBar" Width="126" Height="3" HorizontalAlignment="Left"
                                 Background="Black" BorderBrush="Transparent" Foreground="#FF00ccff" Maximum="100"
                                 Minimum="0" />

                </Grid>

                <ScrollViewer Name="PortfolioScroller" Grid.Row="2" Grid.RowSpan="22" Margin="2,2,2,5"
                              HorizontalAlignment="Stretch" Background="Transparent">
                    <StackPanel Name="PortfolioPanel" />
                </ScrollViewer>

                <Grid Name="CurveGrid" Grid.Row="20" Grid.RowSpan="4" Margin="2,0,0,0"
                      Visibility="Collapsed">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75" />
                        <ColumnDefinition Width="25" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                    </Grid.RowDefinitions>

                    <Rectangle Grid.Row="1" Grid.ColumnSpan="3" Height="1" Margin="5,0,5,22"
                               Fill="Transparent" Stroke="#FF124b72" StrokeThickness="1" />

                    <Rectangle Grid.Row="1" Grid.ColumnSpan="3" Height="1" Margin="5,0,5,22"
                               Fill="Transparent" Stroke="#FF124b72" StrokeThickness="1" />

                    <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="4,4,0,0"
                           HorizontalAlignment="Left" VerticalAlignment="Center" Background="Transparent" Content="Generic Yield Curve"
                           FontFamily="Helvetica Neue" FontSize="11" Foreground="#FFFF8C00" />

                    <Label Grid.Row="1" Grid.Column="0" Margin="4,0,0,0" HorizontalAlignment="Left"
                           VerticalAlignment="Center" Background="Transparent" Content="FT Direction" FontFamily="Helvetica Neue"
                           FontSize="11" Foreground="#FFA0A0A0" />
                    <Label Grid.Row="1" Grid.Column="1" Margin="0,0,0,0" HorizontalAlignment="Left"
                           VerticalAlignment="Center" Background="Transparent" Content="Up" FontFamily="Helvetica Neue"
                           FontSize="11" Foreground="#FFA0A0A0" />
                    <Label Grid.Row="1" Grid.Column="2" Margin="0,0,0,0" HorizontalAlignment="Left"
                           VerticalAlignment="Center" Background="Transparent" Content="Dn" FontFamily="Helvetica Neue"
                           FontSize="11" Foreground="#FFA0A0A0" />

                    <Ellipse Grid.Row="2" Grid.Column="1" Width="9" Height="9"
                             Margin="0,0,0,0" HorizontalAlignment="Center" Fill="Lime" Stroke="Transparent"
                             StrokeThickness="1" />
                    <Ellipse Grid.Row="2" Grid.Column="2" Width="9" Height="9"
                             Margin="0,0,0,0" HorizontalAlignment="Center" Fill="Red" Stroke="Transparent"
                             StrokeThickness="1" />

                    <Label Grid.Row="2" Grid.Column="0" Margin="4,0,0,0" HorizontalAlignment="Left"
                           VerticalAlignment="Center" Background="Transparent" Content="Current" FontFamily="Helvetica Neue"
