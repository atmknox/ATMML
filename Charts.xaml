                       FontSize="9" FontWeight="Normal" Foreground="White" />

                <Label Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="0,0,0,0"
                       HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent" Content=""
                       FontFamily="Helvetica Neue" FontSize="11" FontWeight="Normal" Foreground="#FFF" />

            </Grid>

