                               StrokeThickness="1" />
                    <Rectangle Grid.Row="3" Grid.Column="2" Width="7" Height="7"
                               Margin="0,0,0,0" HorizontalAlignment="Center" Fill="Red" Stroke="Red"
                               StrokeThickness="1" />
                    <Label Grid.Row="3" Grid.Column="0" Margin="4,0,0,0" HorizontalAlignment="Left"
                           VerticalAlignment="Center" Background="Transparent" Content="Historical" FontFamily="Helvetica Neue"
                           FontSize="11" Foreground="#FFA0A0A0" />

                </Grid>


                <Grid Grid.Row="13" Grid.RowSpan="11" Grid.Column="0" Grid.ColumnSpan="3"
                      Margin="4,3,0,0" Visibility="Hidden">

