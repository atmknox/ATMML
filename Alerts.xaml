                    <FlowDocument ColumnWidth="400" IsHyphenationEnabled="True" IsOptimalParagraphEnabled="True">

                        <Section Name="EditSection" FontFamily="Helvetica Neue" FontSize="11" Foreground="#a0a0a0">

                            <Paragraph>
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    EDITING YOUR ALERTS
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                The ATM ALERT provides editing capability to each Alert.
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                Once
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    'SAVED'
                                </Run>
                                the changes to Your Alert are stored for its next use.
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11" />

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    EDIT TOOLS
                                </Run>
                            </Paragraph>

                            <Table CellSpacing="2">
                                <Table.Columns>
                                    <TableColumn Width="150" />
                                    <TableColumn Width="100" />
                                    <TableColumn Width="100" />
                                    <TableColumn Width="100" />
                                    <TableColumn Width="100" />
                                </Table.Columns>

                                <TableRowGroup>

                                    <TableRow Background="#FF124B72" FontSize="11">
                                        <TableCell>
                                            <Paragraph FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#FFFF8C00">
                                                YOUR ALERT TITLE
                                            </Paragraph>
                                        </TableCell>
                                        <TableCell TextAlignment="Justify">
                                            <Paragraph FontFamily="Helvetica Neue" FontSize="11" Foreground="#ff8c00">
                                                &#x2191;
                                            </Paragraph>
                                        </TableCell>
                                        <TableCell TextAlignment="Justify">
                                            <Paragraph FontFamily="Helvetica Neue" FontSize="11" Foreground="#ff8c00">
                                                ROW
                                            </Paragraph>
                                        </TableCell>
                                        <TableCell TextAlignment="Justify">
                                            <Paragraph FontFamily="Helvetica Neue" FontSize="11" Foreground="#ff8c00">
                                                &#x2193;
                                            </Paragraph>
                                        </TableCell>
                                        <TableCell TextAlignment="Justify">
                                            <Paragraph FontFamily="Helvetica Neue" FontSize="11" Foreground="#ff8c00">
                                                &#x1F589;
                                            </Paragraph>
                                        </TableCell>
                                        <TableCell TextAlignment="Justify">
                                            <Paragraph FontFamily="Helvetica Neue" FontSize="11" Foreground="#ff8c00">
                                                X
                                            </Paragraph>
                                        </TableCell>
                                    </TableRow>
                                </TableRowGroup>
                            </Table>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                Alert Editing tools are located on the
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    RIGHT
                                </Run>
                                side of each Alert Bar.
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                They include:
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        Up and Down Arrows
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        A left-facing Pencil
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        A Delete button
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph />

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    &#x2191; AND &#x2193; ARROWS
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                The up and down arrows move Your Alerts up and down the list.
                            </Paragraph>

                            <Paragraph />

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    &#x1F589; PENCIL
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                The Edit Pencil opens the ATM Alert Setup Dialog for the selected Alert to change Securities List, Conditions, and Notifications for the Alert.
                            </Paragraph>

                            <Paragraph />

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    X - DELETE BUTTON
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                The Delete Button represented by a ' X ' will delete the selected Alert.  A Confirm Delete message displays before the Alert is permanently deleted.
                            </Paragraph>

                            <Paragraph />

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    ACCESSING THE DIALOG BOX
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                To access the Alert Dialog box, select the
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    &#x1F589; PENCIL.
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                Each Alert can be edited by:
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        Security List
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        Condition List
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        Name
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        Notification
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        Run Time
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph />

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    EDITING THE SECURITY LIST
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                When you edit an existing Alert, all the previous settings for that Alert display within the dialog.
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                To add additional securities to your Alert, find the group you wish to add select the CHECKBOX next to the group.
                                Remember that Security Lists are
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="YELLOW">
                                    AND
                                </Run>
                                together.  So adding more securities
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    INCREASES
                                </Run>
                                the number of symbols that  met your Alert's criteria.
                            </Paragraph>

                            <Paragraph />

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    EDITING ALERT CONDITIONS
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                To add additional ATM Conditions to your Alert, find the condition or study you wish to add and select the time frame
                                associated with that condition.  Remember that Conditions are
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="YELLOW">
                                    AND
                                </Run>
                                together.  So adding more conditions (which are restrictions)
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    REDUCE
                                </Run>
                                the number of symbols that met your criteria.   And likewise,
                                eliminating conditions (decreasing restrictions) by
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    UNCHECKING
                                </Run>
                                their time frame
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    INCREASES
                                </Run>
                                the number of symbols that met your criteria.
                            </Paragraph>

                            <Paragraph />

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    EDITING THE 
                                    NAME
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                To change the name of your Alert, highlight the name and begin typing.   Once complete, click the
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    SAVE
                                </Run>
                                Button.
                            </Paragraph>
                            <Paragraph />

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    EDITING ALERT NOTIFICATION
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                Notifications can be adjusted:
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        The
                                        <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                            ON - OFF
                                        </Run>
                                        checkbox.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        The
                                        <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                            Alert on Top at Notification
                                        </Run>
                                        checkbox.
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                If the Checkbox is
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    Checked
                                </Run>
                                you are notified of new Alerts, with the following:
                            </Paragraph>
                            <List>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        The
                                        <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="Red">
                                            ALERTS
                                        </Run>
                                        button at the top of the application
                                        <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="Red">
                                            BLINKING
                                        </Run>
                                        and changing to
                                        <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="Red">
                                            RED
                                        </Run>
                                        .
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        A Red Diamond
                                        <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="Red">
                                            &#x2666;
                                        </Run>
                                        displayed to the left of the
                                        <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                            ALERT TITLE
                                        </Run>
                                        .
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                        A Red Diamond
                                        <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="Red">
                                            &#x2666;
                                        </Run>
                                        next to the
                                        <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                            SYMBOL
                                        </Run>
                                        .
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph>
                                To Stop All Notifications,
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    UNCHECK
                                </Run>
                                the checkbox.
                            </Paragraph>

                            <Paragraph>
                                To Stop Alert on top at Notification,
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    UNCHECK
                                </Run>
                                its checkbox.
                            </Paragraph>

                            <Paragraph />

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    EDITING THE ALERT'S RUN TIME
                                </Run>
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                The initial time setting for each Alert is
                                <Run FontFamily="Helvetica Neue" FontSize="11" FontWeight="Regular" Foreground="#ff8c00">
                                    5 minutes .
                                </Run>
                                Usually, this amount is adequate to retrieve the needed data and calculate
                                the required conditions for about 500 securities.  However, should you find the your Alerts do not conclude within the allotted
                                time, lengthen the default.
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                Or, if you would like your Alerts to run less often, lengthen the default.
                            </Paragraph>

                        </Section>

