<ContentControl x:Class="ATMML.Alerts" 
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                xmlns:Themes="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero2" 
                xmlns:local ="clr-namespace:ATMML"
                xmlns:auth="clr-namespace:ATMML.Auth"
                mc:Ignorable="d">

    <ContentControl.Resources>

        <SolidColorBrush x:Key="ChromeBackgroundBrush" Color="Gray" />
        <SolidColorBrush x:Key="ChromeBorderBrush" Color="#4d4d4d" />

        <LinearGradientBrush x:Key="WindowDarkBrush" StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Offset="0" Color="#FF8b99a7" />
            <GradientStop Offset="0.375" Color="#FF627484" />
            <GradientStop Offset="0.375" Color="#FF718597" />
            <GradientStop Offset="1" Color="#FF4c5b67" />
        </LinearGradientBrush>

        <Style x:Key="{x:Type ToolTip}" TargetType="{x:Type ToolTip}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Background" Value="Black" />
            <Setter Property="Foreground" Value="WhiteSmoke" />
        </Style>

        <Style x:Key="ChromeCloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFB1B1B1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Opacity" Value="0.4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Canvas x:Name="Grid" Width="14" Height="14"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Canvas.Left="1" Canvas.Top="1" />
                        </Canvas>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1.0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

