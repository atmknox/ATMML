                                    <TableRow>

                                        <TableCell>
                                            <Paragraph Margin="0,7,10,0" FontFamily="Helvetica Neue" FontSize="11" Foreground="White"
                                                       TextAlignment="Right">
                                                &#x25B6;
                                            </Paragraph>
                                        </TableCell>

                                        <TableCell Background="#FF124B72" FontWeight="Regular" Foreground="Black" LineHeight="25">
                                            <Paragraph Margin="5,7,10,0" Foreground="#FFFF8C00">YOUR ALERT TITLE</Paragraph>
                                        </TableCell>

                                        <TableCell Background="Transparent" FontWeight="Bold" />
                                        <TableCell Background="Transparent" FontWeight="Bold" />
                                        <TableCell Background="Transparent" FontWeight="Bold" />

                                    </TableRow>
                                </TableRowGroup>
                            </Table>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                Selecting the white triangle '
                                <Run FontFamily="Helvetica Neue" FontSize="8" FontWeight="Regular" Foreground="White">
                                    &#x25B6;
                                </Run>
                                ' opens the results for your Alert.
                            </Paragraph>

                            <Paragraph FontFamily="Helvetica Neue" FontSize="11">
                                Selecting the gray triangle '
                                <Run FontFamily="Helvetica Neue" FontSize="10" FontWeight="Regular">
                                    &#x25e2;
                                </Run>
                                ' closes the results.
                            </Paragraph>


