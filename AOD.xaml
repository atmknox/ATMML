                   Content="Close Short" Cursor="Hand" FontFamily="Helvetica Neue" FontSize="9"
                   FontWeight="SemiBold" Foreground="Black" MouseDown="ShortClose_MouseDown" MouseEnter="Trade_MouseEnter"
                   MouseLeave="Trade_MouseLeave" />
            <Label x:Name="ReduceShort1" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                   Margin="10,0,0,0" Padding="0" HorizontalAlignment="Left" VerticalContentAlignment="Center"
                   Content="Reduce 1 Unit" Cursor="Hand" FontFamily="Helvetica Neue" FontSize="9"
                   FontWeight="SemiBold" Foreground="Black" MouseDown="ShortReduce_MouseDown" MouseEnter="Trade_MouseEnter"
                   MouseLeave="Trade_MouseLeave" />
            <Label x:Name="Sell1more" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                   Margin="10,0,0,0" Padding="0" HorizontalAlignment="Left" VerticalContentAlignment="Center"
                   Content="Add 1 Unit" Cursor="Hand" FontFamily="Helvetica Neue" FontSize="9"
                   FontWeight="SemiBold" Foreground="Black" MouseDown="ShortAdd_MouseDown" MouseEnter="Trade_MouseEnter"
                   MouseLeave="Trade_MouseLeave" />
            <Label x:Name="Sell1" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
