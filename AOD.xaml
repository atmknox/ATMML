        <Grid x:Name="Trade" Grid.Row="6" Grid.RowSpan="12" Margin="2,0,2,0"
              Visibility="Collapsed">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
                <RowDefinition Height="15" />
            </Grid.RowDefinitions>

            <Rectangle Grid.Row="6" Grid.RowSpan="6" Grid.Column="1" Margin="2,0,2,0"
                       Fill="Lime" Opacity=".75" />

            <Rectangle Grid.Row="0" Grid.RowSpan="6" Grid.Column="1" Margin="2,2,2,3"
                       Fill="Red" Opacity=".75" />
            <Rectangle Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="12" Height="1"
                       Margin="0,0,0,3" VerticalAlignment="Bottom" Fill="Transparent" Stroke="#FF124B72"
                       StrokeThickness="1" />

            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">

                <Label x:Name="symbolPosition" Margin="2,0,0,0" Padding="2" HorizontalAlignment="Left"
                       Content="Position" FontFamily="Helvetica Neue" FontSize="9" Foreground="White" />
            </StackPanel>

            <ScrollViewer Grid.Row="3" Grid.RowSpan="11" Grid.Column="0" Margin="0,2,2,2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="15" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="15" />
                    </Grid.RowDefinitions>
                    <CheckBox Grid.Row="0" Margin="2,0,0,0" Padding="2" HorizontalAlignment="Left"
                              Content="ALL" FontFamily="Helvetica Neue" FontSize="9" Foreground="White" />
                    <CheckBox Grid.Row="1" Margin="2,0,0,0" Padding="2" HorizontalAlignment="Left"
                              Content="CMR" FontFamily="Helvetica Neue" FontSize="9" Foreground="White" />
                    <CheckBox Grid.Row="2" Margin="2,0,0,0" Padding="2" HorizontalAlignment="Left"
                              Content="SQ PT" FontFamily="Helvetica Neue" FontSize="9" Foreground="White" />
                    <CheckBox Grid.Row="3" Margin="2,0,0,0" Padding="2" HorizontalAlignment="Left"
                              Content="TELK" FontFamily="Helvetica Neue" FontSize="9" Foreground="White" />
                    <CheckBox Grid.Row="4" Margin="2,0,0,0" Padding="2" HorizontalAlignment="Left"
                              Content="TIM" FontFamily="Helvetica Neue" FontSize="9" Foreground="White" />
                    <CheckBox Grid.Row="5" Margin="2,0,0,0" Padding="2" HorizontalAlignment="Left"
                              Content="TMSG" FontFamily="Helvetica Neue" FontSize="9" Foreground="White" />
                </Grid>
            </ScrollViewer>

            <Label x:Name="Buy1" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2"
                   Margin="8,0,0,0" Padding="2" HorizontalAlignment="Left" VerticalContentAlignment="Center"
                   Content="Buy 1 Unit" Cursor="Hand" FontFamily="Helvetica Neue" FontSize="9"
                   FontWeight="SemiBold" Foreground="Black" MouseDown="Long_MouseDown" MouseEnter="Trade_MouseEnter"
                   MouseLeave="Trade_MouseLeave" />
            <Label x:Name="Buy1more" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2"
                   Margin="8,0,0,0" Padding="2" HorizontalAlignment="Left" VerticalContentAlignment="Center"
                   Content="Add 1 Unit" Cursor="Hand" FontFamily="Helvetica Neue" FontSize="9"
                   FontWeight="SemiBold" Foreground="Black" MouseDown="LongAdd_MouseDown" MouseEnter="Trade_MouseEnter"
                   MouseLeave="Trade_MouseLeave" />
            <Label x:Name="ReduceLong1" Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2"
                   Margin="8,0,0,0" Padding="2" HorizontalAlignment="Left" VerticalContentAlignment="Center"
                   Content="Reduce 1 Unit" Cursor="Hand" FontFamily="Helvetica Neue" FontSize="9"
                   FontWeight="SemiBold" Foreground="Black" MouseDown="LongReduce_MouseDown" MouseEnter="Trade_MouseEnter"
                   MouseLeave="Trade_MouseLeave" />
            <Label x:Name="CloseLong" Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2"
                   Margin="8,0,0,0" Padding="2" HorizontalAlignment="Left" VerticalContentAlignment="Top"
                   Content="Close Long" Cursor="Hand" FontFamily="Helvetica Neue" FontSize="9"
                   FontWeight="SemiBold" Foreground="Black" MouseDown="LongClose_MouseDown" MouseEnter="Trade_MouseEnter"
                   MouseLeave="Trade_MouseLeave" />
            <Label x:Name="CloseShort" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
